#!/usr/bin/env bash

WALLPAPER_DIR="$HOME/media/pictures/wallpapers"
HYPRPAPER_CONF="$HOME/.config/hypr/hyprpaper.conf"
HYPRLOCK_CONF="$HOME/.config/hypr/hyprlock.conf"
THUMB_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wallpaper-thumbs"

mkdir -p "$THUMB_DIR"

# build list of files and generate thumbnails
mapfile -t files < <(
  find "$WALLPAPER_DIR" -maxdepth 1 -type f \
    \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' \) \
    -printf '%f\n' | sort
)

# generate missing thumbnails with ffmpeg
for file in "${files[@]}"; do
  thumb="$THUMB_DIR/${file%.*}.png"
  if [ ! -f "$thumb" ] || [ "$WALLPAPER_DIR/$file" -nt "$thumb" ]; then
    ffmpeg -y -i "$WALLPAPER_DIR/$file" \
      -vf "scale=128:72:force_original_aspect_ratio=decrease,pad=128:72:(ow-iw)/2:(oh-ih)/2" \
      "$thumb" 2>/dev/null
  fi
done

# build rofi input: "filename\0icon\x1f/path/to/thumb"
rofi_input=""
for file in "${files[@]}"; do
  thumb="$THUMB_DIR/${file%.*}.png"
  rofi_input+="${file}\0icon\x1f${thumb}\n"
done

# pick via rofi with icons
chosen_file="$(printf '%b' "$rofi_input" | rofi -dmenu -i -p 'wallpaper' \
  -show-icons \
  -theme-str 'element-icon { size: 4em; vertical-align: 0.5; }' \
  -theme-str 'element-text { vertical-align: 0.5; }')"

[ -z "$chosen_file" ] && exit 0

chosen="$WALLPAPER_DIR/$chosen_file"
escaped_path=$(printf '%s\n' "$chosen" | sed 's/[\/&]/\\&/g')

sed -i -E "s|^(\s*path\s*=\s*).*|\1$escaped_path|" "$HYPRPAPER_CONF"
sed -i -E "s|^(\s*path\s*=\s*).*|\1$escaped_path|" "$HYPRLOCK_CONF"

pkill hyprpaper
hyprctl dispatch 'hl.dsp.exec_cmd("hyprpaper")'
